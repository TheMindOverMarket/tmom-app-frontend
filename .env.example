# Frontend env for the TMOM apps
# Configure the deployed deviation engine URL here for Vite builds.
VITE_DEVIATION_ENGINE_BASE_URL=https://your-deviation-engine.onrender.com

# Optional: override the WebSocket URL if it does not match the HTTP base URL.
VITE_DEVIATION_ENGINE_WS_URL=wss://your-deviation-engine.onrender.com/ws/deviation-output

# Optional: configure the Rule Engine websocket explicitly.
VITE_RULE_ENGINE_BASE_URL=https://rule-engine-rcg9.onrender.com
VITE_RULE_ENGINE_WS_URL=wss://rule-engine-rcg9.onrender.com/ws/engine-output
